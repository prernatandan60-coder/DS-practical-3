#include <iostream>
#include <string>
using namespace std;

int binarySearch(string arr[], int n, string key) {
    int low = 0, high = n - 1;

    while (low <= high) {
        int mid = (low + high) / 2;

        if (arr[mid] == key)
            return mid;            // string found
        else if (arr[mid] < key)
            low = mid + 1;         // search right half
        else
            high = mid - 1;        // search left half
    }
    return -1; // string not found
}

int main() {
    int n;
    string key;

    cout << "Enter number of strings: ";
    cin >> n;

    string arr[n];

    cout << "Enter strings in SORTED order:\n";
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    cout << "Enter string to search: ";
    cin >> key;

    int result = binarySearch(arr, n, key);

    if (result != -1)
        cout << "String found at index: " << result;
    else
        cout << "String not found";

    return 0;
}
